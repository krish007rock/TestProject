{
  "name": "portal",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "set NODE_OPTIONS=--openssl-legacy-provider && ng serve --host shared.auth.boeing.com && --ssl false",
    "start_dev": "ng serve --host shared.auth.boeing.com",
    "start_prod": "ng serve --host shared.auth.boeing.com --configuration azure-prod",
    "build": "ng build --build-optimizer=false",
    "build_dev": "npm run ng build -- --configuration azure-dev",
    "build_prod": "npm run ng build -- --configuration azure-prod",
    "test": "ng test --no-watch --code-coverage",
    "test_local": "set NODE_OPTIONS=--openssl-legacy-provider && ng test",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~12.2.17",
    "@angular/cdk": "^12.1.4",
    "@angular/common": "^12.2.17",
    "@angular/compiler": "~12.2.17",
    "@angular/core": "~12.2.17",
    "@angular/forms": "~12.2.17",
    "@angular/material": "^12.1.4",
    "@angular/platform-browser": "~12.2.17",
    "@angular/platform-browser-dynamic": "~12.2.17",
    "@angular/router": "~12.2.17",
    "@microsoft/applicationinsights-web": "^2.8.15",
    "@ngx-pwa/local-storage": "^12.1.0",
    "angular-oauth2-oidc": "12.0.2",
    "angular-oauth2-oidc-jwks": "^12.0.0",
    "chart.js": "^2.9.3",
    "google-libphonenumber": "^3.2.40",
    "material-design-iconic-font": "^2.2.0",
    "material-design-icons": "^3.0.1",
    "ngx-ui-loader": "^11.0.0",
    "rxjs": "^6.6.7",
    "tslib": "^2.6.1",
    "xlsx": "^0.16.8",
    "zone.js": "~0.11.8"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^12.1.4",
    "@angular/cli": "^12.1.4",
    "@angular/compiler-cli": "~12.2.17",
    "@angular/language-service": "~12.2.17",
    "@types/jasmine": "^4.3.5",
    "@types/node": "^12.11.1",
    "codelyzer": "^6.0.0",
    "jasmine-core": "^5.1.0",
    "karma": "^6.4.2",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "protractor": "~7.0.0",
    "ts-node": "~8.3.0",
    "tslint": "~6.1.0",
    "typescript": "~4.3.5"
  }
}
